# ─────────────────────────────────────────────
# MRA - My Rights App  |  Environment Variables
# Add ALL of these in Railway → Variables tab
# ─────────────────────────────────────────────

# 1. AI (Required)
#    Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 2. Email — for OTP verification & notifications (Required for registration)
#    Use your Gmail address
#    Get App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password

# 3. Admin Panel Password (set something strong)
ADMIN_PASSWORD=change-this-to-something-strong

# 4. Your app URL (Railway URL, for email links)
APP_URL=https://mra-production-56be.up.railway.app

# 5. Twilio WhatsApp (Optional)
#    Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# 6. Port (Railway sets this automatically — do not change)
PORT=3000
