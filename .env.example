# Required — Anthropic API key for the AI chat
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Gmail credentials for sending OTP and notification emails
EMAIL_USER=youremail@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# Optional — Admin panel password (default: mra-admin-2024)
ADMIN_PASSWORD=mra-admin-2024

# Optional — Where new lawyer registration notifications are emailed
ADMIN_EMAIL=admin@yourdomain.com

# Optional — Base URL used in email links (set to your Railway domain)
APP_URL=https://your-app.up.railway.app

# Twilio account SID — only needed for the WhatsApp webhook (/webhook/whatsapp)
TWILIO_ACCOUNT_SID=
