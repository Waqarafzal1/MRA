# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — safe to expose; used client-side for the public anon key if needed
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Found in Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required — Anthropic API key for the AI chat
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (Nodemailer / Gmail) ────────────────────────────────────────────────
# Optional — Gmail credentials for sending OTP and notification emails
EMAIL_USER=youremail@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# ── Admin ─────────────────────────────────────────────────────────────────────
# Optional — Admin panel password (default: mra-admin-2024)
ADMIN_PASSWORD=mra-admin-2024

# Optional — Where new lawyer registration notifications are emailed
ADMIN_EMAIL=admin@yourdomain.com

# Optional — Base URL used in email links (set to your Railway/Vercel domain)
APP_URL=https://your-app.up.railway.app

# ── Twilio (optional) ─────────────────────────────────────────────────────────
# Only needed for the WhatsApp webhook (/webhook/whatsapp)
TWILIO_ACCOUNT_SID=
